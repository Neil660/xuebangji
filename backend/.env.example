# ── 服务端口 ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MySQL 数据库 ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=xuebangji
DB_USER=root
DB_PASSWORD=your_password_here

# ── JWT 认证 ──────────────────────────────────────
JWT_ACCESS_SECRET=your_jwt_access_secret_here_min32chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min32chars
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=30d

# ── 文件上传 ──────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── 排行榜 ────────────────────────────────────────
LEADERBOARD_REFRESH_INTERVAL=10
MIN_DAILY_DURATION_FOR_RANK=1800

# ── CORS ──────────────────────────────────────────
CORS_ORIGIN=*

# ── 以下为生产环境可选项 ──────────────────────────

# Redis（生产环境启用，替代内存缓存）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Firebase Cloud Messaging（推送通知）
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# 阿里云短信（生产环境启用，替代开发模式固定验证码）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=学榜记
# ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxxx
